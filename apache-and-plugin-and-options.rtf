\fs40 \cf4 Bootstrap Class for Forked Processes\
\pard\pardeftab720\partightenfactor0

\fs32 \cf4 For ATTACHED and DETACHED modes, you need a bootstrap class that runs in the forked process:\
\
\pard\pardeftab720\partightenfactor0

\fs24 \cf8 \cb9 java\cb1 \
\pard\pardeftab720\partightenfactor0

\fs28 \cf18 \cb9 // Part of launcher-api module (so it's on classpath)\cf11 \
\pard\pardeftab720\partightenfactor0
\cf10 package\cf11  com.example.launcher.bootstrap;\
\
\cf10 public\cf11  \cf10 class\cf11  \cf12 Bootstrap\cf11  \{\
    \
    \cf10 public\cf11  \cf10 static\cf11  \cf10 void\cf11  \cf13 main\cf11 (\cf12 String\cf11 [] args) \{\
        \cf10 try\cf11  \{\
            \cf18 // Read options from environment\cf11 \
            \cf12 MyOptions\cf11  options \cf13 =\cf11  \cf12 MyOptions\cf11 .\cf13 fromEnvironmentVariables\cf11 (\cf12 System\cf11 .\cf13 getenv\cf11 ());\
            \
            \cf18 // Use ServiceLoader to find implementation\cf11 \
            \cf12 ServiceLoader\cf11 <\cf12 Launchable\cf11 > loader \cf13 =\cf11  \cf12 ServiceLoader\cf11 .\cf13 load\cf11 (\cf12 Launchable\cf11 .\cf10 class\cf11 );\
            \cf12 Launchable\cf11  launcher \cf13 =\cf11  loader.\cf13 iterator\cf11 ().\cf13 next\cf11 ();\
            \
            \cf18 // Launch!\cf11 \
            \cf10 int\cf11  exitCode \cf13 =\cf11  launcher.\cf13 launch\cf11 (options.\cf13 toMap\cf11 ());\
            \cf12 System\cf11 .\cf13 exit\cf11 (exitCode);\
            \
        \} \cf10 catch\cf11  (\cf12 Exception\cf11  e) \{\
            e.\cf13 printStackTrace\cf11 ();\
            \cf12 System\cf11 .\cf13 exit\cf11 (\cf12 1\cf11 );\
        \}\
    \}\
\}\cb1 \
\pard\pardeftab720\partightenfactor0

\fs40 \cf4 Alternative for Forked Processes: Direct Main Call\
\pard\pardeftab720\partightenfactor0

\fs32 \cf4 If you don't want to use ServiceLoader in forked processes, just call the regular main():\
\
\pard\pardeftab720\partightenfactor0

\fs24 \cf8 \cb9 java\cb1 \
\pard\pardeftab720\partightenfactor0

\fs28 \cf10 \cb9 public\cf11  \cf10 class\cf11  \cf12 AttachedExecutionStrategy\cf11  \cf10 implements\cf11  \cf12 ExecutionStrategy\cf11  \{\
    \
    \cf10 private\cf11  \cf12 ProcessBuilder\cf11  \cf13 createProcessBuilder\cf11 (\cf12 MyOptions\cf11  options, \cf12 Set\cf11 <\cf12 File\cf11 > targetJars) \{\
        \cf12 List\cf11 <\cf12 String\cf11 > command \cf13 =\cf11  \cf10 new\cf11  \cf12 ArrayList\cf11 <>();\
        command.\cf13 add\cf11 (\cf14 "java"\cf11 );\
        command.\cf13 add\cf11 (\cf14 "-cp"\cf11 );\
        command.\cf13 add\cf11 (\cf13 buildClasspath\cf11 (targetJars));\
        \
        \cf18 // Call the app's actual main class directly\cf11 \
        command.\cf13 add\cf11 (options.\cf13 getMainClassName\cf11 ()); \cf18 // e.g., "com.example.MyApp"\cf11 \
        \
        \cf18 // Add the app's command line args\cf11 \
        command.\cf13 addAll\cf11 (\cf12 Arrays\cf11 .\cf13 asList\cf11 (options.\cf13 getMainClassArgs\cf11 ()));\
        \
        \cf12 ProcessBuilder\cf11  pb \cf13 =\cf11  \cf10 new\cf11  \cf12 ProcessBuilder\cf11 (command);\
        \
        \cf18 // Optionally pass additional config via environment\cf11 \
        pb.\cf13 environment\cf11 ().\cf13 putAll\cf11 (options.\cf13 toEnvironmentVariables\cf11 ());\
        \
        \cf10 return\cf11  pb;\
    \}\
\}\cb1 \
