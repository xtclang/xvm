        \cf12 CommandLineParser\cf11  parser \cf13 =\cf11  \cf10 new\cf11  \cf12 DefaultParser\cf11 ();\
        \cf10 this\cf11 .cmd \cf13 =\cf11  parser.\cf13 parse\cf11 (options, args);\
