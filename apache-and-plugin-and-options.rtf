        pb.\cf13 redirectOutput\cf11 (\cf12 ProcessBuilder\cf11 .\cf12 Redirect\cf11 .\cf10 to\cf11 (\cf10 new\cf11  \cf12 File\cf11 (\cf14 "output.log"\cf11 )));\
        pb.\cf13 redirectError\cf11 (\cf12 ProcessBuilder\cf11 .\cf12 Redirect\cf11 .\cf10 to\cf11 (\cf10 new\cf11  \cf12 File\cf11 (\cf14 "error.log"\cf11 )));\
        \
        pb.\cf13 start\cf11 (); \cf18 // Don't wait\cf11 \
        \cf10 return\cf11  \cf12 0\cf11 ;\
    \}\
    \
    \cf10 private\cf11  \cf12 ProcessBuilder\cf11  \cf13 createProcessBuilder\cf11 (\cf12 MyOptions\cf11  options, \cf12 Set\cf11 <\cf12 File\cf11 > targetJars) \{\
        \cf18 // Same as AttachedExecutionStrategy\cf11 \
        \cf18 // ... (extract to shared method)\cf11 \
    \}\
\}\cb1 \
