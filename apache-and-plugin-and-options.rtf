            .\cf13 hasArg\cf11 ()\
            .\cf13 type\cf11 (\cf12 Number\cf11 .\cf10 class\cf11 )\
            .\cf13 desc\cf11 (\cf14 "Count"\cf11 )\
            .\cf13 build\cf11 ());\
