{
    "name": "xtc-language",
    "displayName": "Ecstasy Language Support",
    "description": "Visual Studio Code support for the Ecstasy programming language (also known by its file extension and informal short-form, XTC). Source files use the .x extension. Includes syntax highlighting, LSP-based language features (hover, completion, go-to-definition), debugging via DAP, snippets, and project scaffolding.",
    "version": "0.4.4",
    "publisher": "xtclang",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/xtclang/xvm"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "Programming Languages",
        "Debuggers",
        "Snippets",
        "Formatters"
    ],
    "keywords": [
        "ecstasy",
        "ecstasy-language",
        "xtc",
        "xvm",
        "xtclang",
        "xdk"
    ],
    "icon": "icons/xtc.png",
    "galleryBanner": {
        "color": "#1f2937",
        "theme": "dark"
    },
    "activationEvents": [
        "onStartupFinished",
        "onLanguage:xtc",
        "workspaceContains:**/*.x"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "xtc",
                "aliases": [
                    "Ecstasy",
                    "XTC",
                    "xtc"
                ],
                "extensions": [
                    ".x"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/xtc-file.png",
                    "dark": "./icons/xtc-file.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "xtc",
                "scopeName": "source.xtc",
                "path": "./syntaxes/xtc.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "xtc",
                "path": "./snippets/xtc.json"
            }
        ],
        "commands": [
            {
                "command": "xtc.createProject",
                "title": "Ecstasy: Create New Project"
            },
            {
                "command": "xtc.runModule",
                "title": "Ecstasy: Run Module"
            },
            {
                "command": "xtc.restartServer",
                "title": "Ecstasy: Restart Language Server"
            },
            {
                "command": "xtc.showServerOutput",
                "title": "Ecstasy: Show Language Server Output"
            }
        ],
        "taskDefinitions": [
            {
                "type": "xtc",
                "required": [
                    "moduleName"
                ],
                "properties": {
                    "moduleName": {
                        "type": "string",
                        "description": "The Ecstasy (.xtc) module to run"
                    },
                    "methodName": {
                        "type": "string",
                        "description": "Method to invoke (defaults to 'run')"
                    },
                    "moduleArguments": {
                        "type": "string",
                        "description": "Comma-separated arguments passed to the module"
                    },
                    "useGradle": {
                        "type": "boolean",
                        "default": true,
                        "description": "Use Gradle to run (recommended for projects with build.gradle.kts)"
                    },
                    "quietMode": {
                        "type": "boolean",
                        "default": true,
                        "description": "Use -q flag for less verbose Gradle output"
                    }
                }
            }
        ],
        "configuration": {
            "title": "Ecstasy",
            "properties": {
                "xtc.java.home": {
                    "type": "string",
                    "default": "",
                    "description": "Path to Java 25+ installation (overrides JAVA_HOME). Leave empty to use JAVA_HOME or 'java' in PATH.",
                    "scope": "machine-overridable"
                },
                "xtc.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace communication between VS Code and the XTC Language Server (for debugging)"
                },
                "xtc.inlayHints.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable inlay hints from the XTC Language Server"
                },
                "xtc.formatting.indentSize": {
                    "type": "integer",
                    "default": 4,
                    "description": "Number of spaces per indentation level"
                },
                "xtc.formatting.continuationIndentSize": {
                    "type": "integer",
                    "default": 8,
                    "description": "Number of spaces for continuation lines"
                },
                "xtc.formatting.tabSize": {
                    "type": "integer",
                    "default": 4,
                    "description": "Tab width in spaces"
                },
                "xtc.formatting.insertSpaces": {
                    "type": "boolean",
                    "default": true,
                    "description": "Use spaces instead of tabs"
                },
                "xtc.formatting.maxLineWidth": {
                    "type": "integer",
                    "default": 120,
                    "description": "Maximum line width (right margin)"
                },
                "xtc.sourceRoots": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Extra source root directories the XTC Language Server indexes (e.g. XDK standard-library sources). Accepts absolute paths to directories that contain .x source files outside the open workspace.",
                    "scope": "machine-overridable"
                }
            }
        },
        "configurationDefaults": {
            "files.associations": {
                "*.x": "xtc"
            },
            "[xtc]": {
                "editor.tabSize": 4,
                "editor.insertSpaces": true,
                "editor.formatOnType": true,
                "editor.autoIndent": "full",
                "editor.semanticHighlighting.enabled": true,
                "editor.bracketPairColorization.enabled": true,
                "editor.guides.bracketPairs": "active",
                "editor.suggest.snippetsPreventQuickSuggestions": false,
                "editor.wordBasedSuggestions": "off"
            }
        },
        "debuggers": [
            {
                "type": "xtc",
                "label": "Ecstasy Debug",
                "languages": [
                    "xtc"
                ],
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "module"
                        ],
                        "properties": {
                            "module": {
                                "type": "string",
                                "description": "The Ecstasy (.xtc) module to debug"
                            },
                            "method": {
                                "type": "string",
                                "description": "Method to invoke (defaults to 'run')",
                                "default": "run"
                            },
                            "args": {
                                "type": "string",
                                "description": "Comma-separated arguments passed to the module"
                            },
                            "cwd": {
                                "type": "string",
                                "description": "Working directory",
                                "default": "${workspaceFolder}"
                            }
                        }
                    }
                },
                "configurationSnippets": [
                    {
                        "label": "Ecstasy: Launch Module",
                        "description": "Launch and debug an Ecstasy module",
                        "body": {
                            "type": "xtc",
                            "request": "launch",
                            "name": "Debug ${1:module}",
                            "module": "${1:myapp}"
                        }
                    }
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "lint": "eslint src/",
        "test:vscode": "node ./scripts/run-vscode-tests.cjs"
    },
    "dependencies": {
        "jdk-utils": "^0.6.0",
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.10.0",
        "@types/vscode": "^1.96.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.2.0",
        "eslint": "^9.17.0",
        "glob": "^11.0.3",
        "mocha": "^11.7.4",
        "sharp": "^0.34.5",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.19.0"
    }
}
