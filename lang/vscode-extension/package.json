{
    "name": "xtc-language",
    "displayName": "XTC Language Support",
    "description": "XTC language support with syntax highlighting and LSP features",
    "version": "0.4.4",
    "publisher": "xtclang",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/xtclang/xvm"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "xtc",
        "xvm"
    ],
    "activationEvents": [
        "onLanguage:xtc"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "xtc",
                "aliases": [
                    "XTC",
                    "xtc"
                ],
                "extensions": [
                    ".x"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/xtc.svg",
                    "dark": "./icons/xtc.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "xtc",
                "scopeName": "source.xtc",
                "path": "./syntaxes/xtc.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "xtc",
                "path": "./snippets/xtc.json"
            }
        ],
        "commands": [
            {
                "command": "xtc.createProject",
                "title": "XTC: Create New Project"
            }
        ],
        "configuration": {
            "title": "XTC Language",
            "properties": {
                "xtc.formatting.indentSize": {
                    "type": "integer",
                    "default": 4,
                    "description": "Number of spaces per indentation level"
                },
                "xtc.formatting.continuationIndentSize": {
                    "type": "integer",
                    "default": 8,
                    "description": "Number of spaces for continuation lines"
                },
                "xtc.formatting.tabSize": {
                    "type": "integer",
                    "default": 4,
                    "description": "Tab width in spaces"
                },
                "xtc.formatting.insertSpaces": {
                    "type": "boolean",
                    "default": true,
                    "description": "Use spaces instead of tabs"
                },
                "xtc.formatting.maxLineWidth": {
                    "type": "integer",
                    "default": 120,
                    "description": "Maximum line width (right margin)"
                }
            }
        },
        "configurationDefaults": {
            "[xtc]": {
                "editor.tabSize": 4,
                "editor.insertSpaces": true,
                "editor.formatOnType": true
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "lint": "eslint src/"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/node": "^22.10.0",
        "@types/vscode": "^1.96.0",
        "@vscode/vsce": "^3.2.0",
        "eslint": "^9.17.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.19.0"
    }
}
