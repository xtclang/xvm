{
    "Module": {
        "prefix": "mod",
        "body": ["module ${1:mymodule} {", "    $0", "}"],
        "description": "Module declaration"
    },
    "Class": {
        "prefix": "cls",
        "body": ["class ${1:MyClass} {", "    $0", "}"],
        "description": "Class declaration"
    },
    "Interface": {
        "prefix": "iface",
        "body": ["interface ${1:MyInterface} {", "    $0", "}"],
        "description": "Interface declaration"
    },
    "Service": {
        "prefix": "svc",
        "body": ["service ${1:MyService} {", "    $0", "}"],
        "description": "Service declaration"
    },
    "Mixin": {
        "prefix": "mix",
        "body": ["mixin ${1:MyMixin} into ${2:Object} {", "    $0", "}"],
        "description": "Mixin declaration"
    },
    "Enum": {
        "prefix": "enu",
        "body": ["enum ${1:MyEnum} {", "    ${2:Value1, Value2}", "}"],
        "description": "Enum declaration"
    },
    "Const": {
        "prefix": "con",
        "body": ["const ${1:MyConst}(${2});"],
        "description": "Const (immutable class) declaration"
    },
    "Package Import": {
        "prefix": "pkg",
        "body": ["package ${1:json} import ${2:json.xtclang.org};"],
        "description": "Package import declaration"
    },
    "Method": {
        "prefix": "meth",
        "body": ["${1:void} ${2:myMethod}(${3}) {", "    $0", "}"],
        "description": "Method declaration"
    },
    "Run Method": {
        "prefix": "run",
        "body": ["void run() {", "    @Inject Console console;", "    $0", "}"],
        "description": "Module run() method with Console injection"
    },
    "Run Method with Args": {
        "prefix": "runa",
        "body": ["void run(String[] args=[]) {", "    @Inject Console console;", "    $0", "}"],
        "description": "Module run() method with args and Console"
    },
    "Property": {
        "prefix": "prop",
        "body": ["${1:String} ${2:name};"],
        "description": "Property declaration"
    },
    "Read-Only Property": {
        "prefix": "roprop",
        "body": ["@RO ${1:Boolean} ${2:empty}.get() = ${3:size == 0};"],
        "description": "Read-only computed property"
    },
    "Constructor": {
        "prefix": "construct",
        "body": ["construct(${1}) {", "    $0", "}"],
        "description": "Constructor declaration"
    },
    "If": {
        "prefix": "if",
        "body": ["if (${1:condition}) {", "    $0", "}"],
        "description": "If statement"
    },
    "If-Else": {
        "prefix": "ife",
        "body": ["if (${1:condition}) {", "    $2", "} else {", "    $0", "}"],
        "description": "If-else statement"
    },
    "If Conditional Assignment": {
        "prefix": "ifv",
        "body": ["if (${1:Value} ${2:value} := ${3:get(key)}) {", "    $0", "}"],
        "description": "If with conditional assignment"
    },
    "For Loop (Range)": {
        "prefix": "fori",
        "body": ["for (Int ${1:i} : 0 ..< ${2:count}) {", "    $0", "}"],
        "description": "Indexed for loop (range-based)"
    },
    "For Loop (Inclusive Range)": {
        "prefix": "forr",
        "body": ["for (Int ${1:x} : ${2:1}..${3:100}) {", "    $0", "}"],
        "description": "For loop over inclusive range"
    },
    "For Each": {
        "prefix": "fore",
        "body": ["for (${1:Element} ${2:item} : ${3:collection}) {", "    $0", "}"],
        "description": "For-each loop"
    },
    "While": {
        "prefix": "while",
        "body": ["while (${1:condition}) {", "    $0", "}"],
        "description": "While loop"
    },
    "Switch": {
        "prefix": "switch",
        "body": ["switch (${1:value}) {", "    case ${2:0}: $0", "}"],
        "description": "Switch statement"
    },
    "Try-Catch": {
        "prefix": "try",
        "body": ["try {", "    $1", "} catch (${2:Exception} e) {", "    $0", "}"],
        "description": "Try-catch block"
    },
    "Using": {
        "prefix": "using",
        "body": ["using (${1:resource}) {", "    $0", "}"],
        "description": "Using statement (auto-close resource)"
    },
    "Assert": {
        "prefix": "assert",
        "body": ["assert ${1:condition};"],
        "description": "Assert statement"
    },
    "Assert with Message": {
        "prefix": "assertm",
        "body": ["assert ${1:condition} as ${2:\"assertion failed\"};"],
        "description": "Assert with message"
    },
    "Console Print (with Inject)": {
        "prefix": "sout",
        "body": ["@Inject Console console;", "console.print($0);"],
        "description": "Console print with @Inject"
    },
    "Console Print": {
        "prefix": "print",
        "body": ["console.print($0);"],
        "description": "Console print (assumes console already injected)"
    },
    "Inject": {
        "prefix": "inject",
        "body": ["@Inject ${1:Console} ${2:console};"],
        "description": "@Inject dependency"
    },
    "Lazy Property": {
        "prefix": "lazy",
        "body": ["private @Lazy ${1:String} ${2:value}.calc() {", "    return $0;", "}"],
        "description": "Lazy-initialized property"
    },
    "Lambda": {
        "prefix": "lambda",
        "body": ["(${1}) -> $0"],
        "description": "Lambda expression"
    },
    "Conditional Method": {
        "prefix": "cond",
        "body": ["conditional ${1:Value} ${2:find}() {", "    $0", "}"],
        "description": "Conditional return method"
    },
    "Doc Comment": {
        "prefix": "doc",
        "body": ["/**", " * ${1:TODO: add description}", " */"],
        "description": "Documentation comment"
    },
    "TODO": {
        "prefix": "todo",
        "body": ["// TODO $0"],
        "description": "TODO comment"
    },
    "WebApp Module": {
        "prefix": "webapp",
        "body": [
            "@WebApp",
            "module ${1:MyServer} {",
            "    package web   import web.xtclang.org;",
            "    package xenia import xenia.xtclang.org;",
            "",
            "    void run() {",
            "        xenia.createServer(this, new HostInfo(\"localhost\", 8080, 8090));",
            "    }",
            "",
            "    @WebService(\"/\")",
            "    service Root {",
            "        @Get",
            "        String hello() = \"Hello, World!\";",
            "    }",
            "}"
        ],
        "description": "WebApp module with web service"
    },
    "WebService": {
        "prefix": "websvc",
        "body": [
            "@WebService(\"${1:/}\")",
            "service ${2:MyService} {",
            "    @Get",
            "    String ${3:hello}() = $0;",
            "}"
        ],
        "description": "WebService declaration"
    },
    "Hello World": {
        "prefix": "hello",
        "body": [
            "module ${1:HelloWorld} {",
            "    void run() {",
            "        @Inject Console console;",
            "        console.print(\"Hello, World!\");",
            "    }",
            "}"
        ],
        "description": "Hello World module (complete file)"
    }
}
