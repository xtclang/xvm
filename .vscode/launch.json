{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run XTC Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/lang/vscode-extension",
                "${workspaceFolder}"
            ],
            "outFiles": [
                "${workspaceFolder}/lang/vscode-extension/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile - lang/vscode-extension"
        }
    ]
}
